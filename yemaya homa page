<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Yemayá Zeilcharter | Luxe zeilbeleving in Zeeland</title>
  <meta name="description" content="Ervaar Yemayá Zeilcharter aan boord van een Sweden Yachts 45. Dagtochten, weekends, midweeks, events en culinaire zeilbeleving vanuit Wemeldinge." />
  <style>
    :root{
      --bg:#071824;
      --bg-soft:#0c2334;
      --card:#0f2b40;
      --card-2:#133550;
      --line:rgba(255,255,255,.10);
      --text:#eaf3f8;
      --muted:#a8bfce;
      --gold:#d9ab52;
      --gold-2:#f1c977;
      --white:#ffffff;
      --shadow:0 20px 50px rgba(0,0,0,.28);
      --radius:22px;
      --max:1200px;
    }

    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{
      font-family:Inter,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
      background:
        radial-gradient(circle at top, rgba(34,91,128,.18), transparent 35%),
        linear-gradient(180deg, #06131d 0%, #081c29 100%);
      color:var(--text);
      line-height:1.6;
      overflow-x:hidden;
    }
    a{text-decoration:none;color:inherit}
    img{display:block;max-width:100%}
    button{font:inherit}

    .container{
      width:min(var(--max), calc(100% - 32px));
      margin:0 auto;
    }

    .section{
      padding:88px 0;
      position:relative;
    }

    .section-head{
      max-width:760px;
      margin-bottom:28px;
    }
    .eyebrow{
      display:inline-block;
      color:var(--gold-2);
      letter-spacing:.12em;
      text-transform:uppercase;
      font-size:12px;
      font-weight:800;
      margin-bottom:10px;
    }
    .section-head h2{
      font-size:clamp(28px,4vw,44px);
      line-height:1.1;
      margin-bottom:12px;
    }
    .section-head p{
      color:var(--muted);
      font-size:17px;
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      padding:14px 22px;
      border-radius:999px;
      border:1px solid transparent;
      font-weight:700;
      transition:.22s ease;
      cursor:pointer;
      white-space:nowrap;
    }
    .btn-primary{
      background:linear-gradient(135deg, var(--gold), var(--gold-2));
      color:#1a1a1a;
      box-shadow:0 8px 24px rgba(217,171,82,.25);
    }
    .btn-primary:hover{transform:translateY(-2px);filter:brightness(1.02)}
    .btn-outline{
      border-color:rgba(255,255,255,.18);
      background:rgba(255,255,255,.03);
      color:var(--text);
    }
    .btn-outline:hover{
      background:rgba(255,255,255,.06);
      transform:translateY(-2px);
    }

    .card{
      background:linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.02));
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      backdrop-filter:blur(10px);
    }

    /* Header */
    .header{
      position:sticky;
      top:0;
      z-index:1000;
      backdrop-filter:blur(14px);
      background:rgba(5,14,22,.72);
      border-bottom:1px solid rgba(255,255,255,.08);
    }
    .nav{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
      min-height:78px;
    }
    .brand{
      display:flex;
      align-items:center;
      gap:12px;
      min-width:0;
    }
    .brand-badge{
      width:42px;
      height:42px;
      border-radius:50%;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg, var(--gold), var(--gold-2));
      color:#14202a;
      font-weight:900;
      box-shadow:0 10px 26px rgba(217,171,82,.24);
      flex:none;
    }
    .brand-text{
      font-weight:800;
      letter-spacing:.02em;
    }
    .brand-text small{
      display:block;
      color:var(--muted);
      font-weight:600;
      font-size:12px;
      letter-spacing:.08em;
      text-transform:uppercase;
    }
    .nav-links{
      display:flex;
      align-items:center;
      gap:18px;
      flex-wrap:wrap;
    }
    .nav-links a{
      color:var(--muted);
      font-size:15px;
      transition:.2s ease;
      position:relative;
    }
    .nav-links a:hover,
    .nav-links a.active{
      color:var(--text);
    }
    .nav-links a::after{
      content:"";
      position:absolute;
      left:0;
      bottom:-6px;
      width:0;
      height:2px;
      background:var(--gold);
      transition:.22s ease;
    }
    .nav-links a:hover::after,
    .nav-links a.active::after{
      width:100%;
    }
    .nav-cta{
      display:flex;
      gap:10px;
      align-items:center;
    }
    .menu-toggle{
      display:none;
      width:44px;
      height:44px;
      border-radius:12px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.04);
      color:var(--text);
      cursor:pointer;
    }
    .mobile-menu{
      display:none;
      padding:0 0 18px;
    }
    .mobile-menu.open{display:block}
    .mobile-menu .mobile-links{
      display:grid;
      gap:10px;
      background:rgba(255,255,255,.03);
      border:1px solid var(--line);
      border-radius:18px;
      padding:14px;
    }
    .mobile-menu a{
      color:var(--text);
      padding:10px 12px;
      border-radius:12px;
      background:rgba(255,255,255,.03);
    }

    /* Hero */
    .hero{
      padding:34px 0 36px;
      position:relative;
      overflow:hidden;
    }
    .hero-wrap{
      display:grid;
      grid-template-columns:1.08fr .92fr;
      gap:28px;
      align-items:stretch;
    }
    .hero-copy{
      padding:34px;
      min-height:620px;
      display:flex;
      flex-direction:column;
      justify-content:center;
      position:relative;
      overflow:hidden;
    }
    .hero-copy::before{
      content:"";
      position:absolute;
      inset:auto -80px -80px auto;
      width:240px;
      height:240px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(217,171,82,.18), transparent 70%);
      pointer-events:none;
    }
    .hero-pill{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:8px 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      color:var(--gold-2);
      width:max-content;
      margin-bottom:16px;
      font-size:12px;
      text-transform:uppercase;
      letter-spacing:.1em;
      font-weight:800;
    }
    .hero-copy h1{
      font-size:clamp(38px,6vw,66px);
      line-height:1.02;
      margin-bottom:16px;
      max-width:12ch;
    }
    .hero-copy p{
      color:var(--muted);
      font-size:18px;
      max-width:650px;
      margin-bottom:22px;
    }
    .hero-actions{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      margin-bottom:22px;
    }
    .hero-tags{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:6px;
    }
    .hero-tags span{
      padding:10px 14px;
      border-radius:999px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.08);
      color:var(--text);
      font-size:14px;
    }

    .hero-slider{
      min-height:620px;
      overflow:hidden;
      position:relative;
    }
    .slides{
      height:100%;
      position:relative;
    }
    .slide{
      position:absolute;
      inset:0;
      opacity:0;
      transform:scale(1.04);
      transition:opacity .7s ease, transform 4.5s ease;
      background-size:cover;
      background-position:center;
    }
    .slide.active{
      opacity:1;
      transform:scale(1);
    }
    .slide::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(180deg, rgba(5,14,22,.15), rgba(5,14,22,.55));
    }
    .slide-caption{
      position:absolute;
      left:24px;
      right:24px;
      bottom:22px;
      z-index:2;
      padding:18px 18px 16px;
      border-radius:18px;
      background:rgba(5,14,22,.56);
      border:1px solid rgba(255,255,255,.10);
      backdrop-filter:blur(10px);
    }
    .slide-caption strong{
      display:block;
      font-size:22px;
      margin-bottom:6px;
    }
    .slide-caption span{
      color:var(--muted);
      font-size:14px;
    }

    .slider-controls{
      position:absolute;
      top:18px;
      right:18px;
      z-index:3;
      display:flex;
      gap:8px;
    }
    .slider-btn{
      width:42px;
      height:42px;
      border:none;
      border-radius:50%;
      background:rgba(255,255,255,.10);
      color:var(--white);
      backdrop-filter:blur(10px);
      cursor:pointer;
      transition:.2s ease;
    }
    .slider-btn:hover{background:rgba(255,255,255,.18)}
    .slider-dots{
      position:absolute;
      left:24px;
      bottom:110px;
      z-index:3;
      display:flex;
      gap:8px;
    }
    .slider-dots button{
      width:10px;
      height:10px;
      border:none;
      border-radius:999px;
      background:rgba(255,255,255,.32);
      cursor:pointer;
      transition:.22s ease;
    }
    .slider-dots button.active{
      width:28px;
      background:var(--gold);
    }

    /* stats */
    .stats{
      margin-top:22px;
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:16px;
    }
    .stat{
      padding:20px;
      text-align:left;
    }
    .stat strong{
      display:block;
      font-size:34px;
      line-height:1;
      color:var(--gold-2);
      margin-bottom:8px;
    }
    .stat span{
      color:var(--muted);
      font-size:14px;
    }

    /* grids */
    .grid-2{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:22px;
    }
    .grid-3{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:22px;
    }
    .grid-4{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:18px;
    }

    .content-card{
      padding:24px;
      height:100%;
      transition:transform .2s ease, border-color .2s ease;
    }
    .content-card:hover{
      transform:translateY(-4px);
      border-color:rgba(217,171,82,.34);
    }
    .content-card h3{
      font-size:24px;
      margin-bottom:10px;
    }
    .content-card p{
      color:var(--muted);
      margin-bottom:12px;
    }
    .list{
      list-style:none;
      display:grid;
      gap:10px;
      margin-top:10px;
    }
    .list li{
      position:relative;
      padding-left:18px;
      color:var(--text);
    }
    .list li::before{
      content:"";
      width:8px;
      height:8px;
      border-radius:50%;
      background:var(--gold);
      position:absolute;
      left:0;
      top:10px;
      box-shadow:0 0 0 6px rgba(217,171,82,.10);
    }

    /* tabs */
    .tabs{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin:12px 0 18px;
    }
    .tab-btn{
      border:none;
      padding:12px 16px;
      border-radius:999px;
      background:rgba(255,255,255,.04);
      color:var(--text);
      border:1px solid rgba(255,255,255,.08);
      cursor:pointer;
      font-weight:700;
      transition:.2s ease;
    }
    .tab-btn.active{
      background:linear-gradient(135deg, var(--gold), var(--gold-2));
      color:#1a1a1a;
      border-color:transparent;
    }
    .tab-panel{
      display:none;
    }
    .tab-panel.active{
      display:grid;
    }

    /* gallery */
    .gallery-grid{
      display:grid;
      grid-template-columns:2fr 1fr 1fr;
      gap:16px;
      grid-auto-rows:230px;
    }
    .gallery-item{
      position:relative;
      overflow:hidden;
      border-radius:20px;
      cursor:pointer;
      border:1px solid var(--line);
      box-shadow:var(--shadow);
      isolation:isolate;
    }
    .gallery-item:nth-child(1){grid-row:span 2}
    .gallery-item img{
      width:100%;
      height:100%;
      object-fit:cover;
      transition:transform .5s ease;
      filter:saturate(1.05);
    }
    .gallery-item:hover img{transform:scale(1.06)}
    .gallery-item::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(180deg, transparent 35%, rgba(5,14,22,.62) 100%);
      z-index:1;
    }
    .gallery-item span{
      position:absolute;
      left:18px;
      right:18px;
      bottom:14px;
      z-index:2;
      font-weight:700;
      font-size:16px;
    }

    /* feature band */
    .feature-band{
      display:grid;
      grid-template-columns:.95fr 1.05fr;
      gap:26px;
      align-items:center;
    }
    .feature-photo{
      min-height:520px;
      overflow:hidden;
      position:relative;
    }
    .feature-photo img{
      width:100%;
      height:100%;
      object-fit:cover;
    }
    .feature-copy{
      padding:30px;
    }
    .feature-copy h3{
      font-size:32px;
      margin-bottom:10px;
    }
    .feature-copy p{
      color:var(--muted);
      margin-bottom:14px;
    }

    /* testimonials */
    .testimonial-wrap{
      position:relative;
      overflow:hidden;
    }
    .testimonial-track{
      display:flex;
      transition:transform .5s ease;
    }
    .testimonial{
      min-width:100%;
      padding:28px;
    }
    .testimonial p{
      font-size:20px;
      color:var(--text);
      margin-bottom:18px;
    }
    .testimonial strong{
      color:var(--gold-2);
      display:block;
    }
    .testimonial small{
      color:var(--muted);
    }

    /* faq */
    .faq{
      display:grid;
      gap:14px;
    }
    .faq-item{
      overflow:hidden;
    }
    .faq-q{
      width:100%;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
      text-align:left;
      padding:18px 20px;
      background:transparent;
      color:var(--text);
      border:none;
      cursor:pointer;
      font-weight:800;
      font-size:18px;
    }
    .faq-q span:last-child{
      color:var(--gold-2);
      font-size:24px;
      line-height:1;
    }
    .faq-a{
      max-height:0;
      overflow:hidden;
      transition:max-height .32s ease;
      color:var(--muted);
      padding:0 20px;
    }
    .faq-a-inner{
      padding:0 0 18px;
    }

    /* contact */
    .contact-box{
      padding:34px;
      display:grid;
      grid-template-columns:1.05fr .95fr;
      gap:24px;
      background:
        radial-gradient(circle at top right, rgba(217,171,82,.12), transparent 25%),
        linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.02));
    }
    .contact-box h3{
      font-size:36px;
      line-height:1.08;
      margin-bottom:12px;
    }
    .contact-box p{
      color:var(--muted);
      margin-bottom:18px;
    }
    .contact-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:16px;
      margin-top:18px;
    }
    .contact-mini{
      padding:18px;
      border-radius:18px;
      background:rgba(255,255,255,.03);
      border:1px solid rgba(255,255,255,.08);
    }
    .contact-mini h4{
      font-size:13px;
      text-transform:uppercase;
      letter-spacing:.12em;
      color:var(--gold-2);
      margin-bottom:8px;
    }
    .contact-mini p,
    .contact-mini a{
      color:var(--text);
      font-size:15px;
      word-break:break-word;
    }

    /* lightbox */
    .lightbox{
      position:fixed;
      inset:0;
      background:rgba(3,9,14,.90);
      display:none;
      align-items:center;
      justify-content:center;
      z-index:2000;
      padding:26px;
    }
    .lightbox.open{display:flex}
    .lightbox-inner{
      position:relative;
      max-width:1100px;
      width:100%;
    }
    .lightbox img{
      width:100%;
      max-height:82vh;
      object-fit:contain;
      border-radius:18px;
      border:1px solid rgba(255,255,255,.12);
      box-shadow:var(--shadow);
    }
    .lightbox-close,
    .lightbox-prev,
    .lightbox-next{
      position:absolute;
      border:none;
      width:48px;
      height:48px;
      border-radius:50%;
      background:rgba(255,255,255,.12);
      color:#fff;
      cursor:pointer;
      backdrop-filter:blur(10px);
    }
    .lightbox-close{top:-16px;right:-10px}
    .lightbox-prev{left:12px;top:50%;transform:translateY(-50%)}
    .lightbox-next{right:12px;top:50%;transform:translateY(-50%)}

    /* reveal */
    .reveal{
      opacity:0;
      transform:translateY(24px);
      transition:opacity .7s ease, transform .7s ease;
    }
    .reveal.visible{
      opacity:1;
      transform:translateY(0);
    }

    /* footer */
    .footer{
      padding:26px 0 40px;
      color:var(--muted);
      font-size:14px;
    }
    .footer-row{
      display:flex;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
      padding-top:18px;
      border-top:1px solid rgba(255,255,255,.08);
    }
    .footer-links{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
    }
    .footer a:hover{color:var(--text)}

    @media (max-width:1080px){
      .hero-wrap,
      .feature-band,
      .contact-box{
        grid-template-columns:1fr;
      }
      .hero-copy,
      .hero-slider{
        min-height:unset;
      }
      .stats,
      .grid-4{
        grid-template-columns:repeat(2,1fr);
      }
      .gallery-grid{
        grid-template-columns:1fr 1fr;
      }
      .gallery-item:nth-child(1){
        grid-column:span 2;
        grid-row:span 1;
      }
      .contact-grid{
        grid-template-columns:1fr;
      }
    }

    @media (max-width:840px){
      .nav-links,.nav-cta .btn{display:none}
      .menu-toggle{display:inline-grid;place-items:center}
      .stats,
      .grid-2,
      .grid-3,
      .grid-4,
      .gallery-grid{
        grid-template-columns:1fr;
      }
      .gallery-item:nth-child(1){grid-column:auto}
      .section{padding:72px 0}
      .hero-copy{padding:24px}
      .hero-copy h1{max-width:none}
    }

    @media (prefers-reduced-motion: reduce){
      *{scroll-behavior:auto}
      .slide,.testimonial-track,.reveal{transition:none!important}
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="container nav">
      <a href="#" class="brand">
        <div class="brand-badge">YZ</div>
        <div class="brand-text">
          Yemayá Zeilcharter
          <small>Wemeldinge • Zeeland</small>
        </div>
      </a>

      <nav class="nav-links">
        <a href="#hero" class="active">Home</a>
        <a href="#over">Over ons</a>
        <a href="#arrangementen">Arrangementen</a>
        <a href="#schip">Het schip</a>
        <a href="#gallery">Galerij</a>
        <a href="#faq">FAQ</a>
        <a href="#contact">Contact</a>
      </nav>

      <div class="nav-cta">
        <a href="tel:+32465084288" class="btn btn-outline">Bel ons</a>
        <a href="#contact" class="btn btn-primary">Boek uw tocht</a>
      </div>

      <button class="menu-toggle" id="menuToggle" aria-label="Open menu">☰</button>
    </div>

    <div class="container mobile-menu" id="mobileMenu">
      <div class="mobile-links">
        <a href="#hero">Home</a>
        <a href="#over">Over ons</a>
        <a href="#arrangementen">Arrangementen</a>
        <a href="#schip">Het schip</a>
        <a href="#gallery">Galerij</a>
        <a href="#faq">FAQ</a>
        <a href="#contact">Contact</a>
      </div>
    </div>
  </header>

  <main>
    <!-- HERO -->
    <section class="hero" id="hero">
      <div class="container hero-wrap">
        <div class="card hero-copy reveal visible">
          <div class="hero-pill">Exclusieve zeilbeleving in Zeeland</div>
          <h1>Vakantie op het water, maar dan écht professioneel</h1>
          <p>
            Stap aan boord van Yemayá en beleef een stijlvolle, comfortabele en persoonlijke zeilervaring
            met een Sweden Yachts 45, gratis schipper en arrangementen voor gezinnen, vrienden en bedrijven.
          </p>
          <div class="hero-actions">
            <a href="#arrangementen" class="btn btn-primary">Bekijk arrangementen</a>
            <a href="#gallery" class="btn btn-outline">Bekijk foto’s</a>
          </div>
          <div class="hero-tags">
            <span>Sweden Yachts 45</span>
            <span>14,10 meter</span>
            <span>Gratis schipper</span>
            <span>Dag, weekend & midweek</span>
          </div>

          <div class="stats">
            <div class="card stat">
              <strong data-count="14">0</strong>
              <span>Meter zeiljacht</span>
            </div>
            <div class="card stat">
              <strong data-count="8">0</strong>
              <span>Personen per dagtocht</span>
            </div>
            <div class="card stat">
              <strong data-count="2">0</strong>
              <span>Gastenkajuiten</span>
